DEBUG=1
SECRET_KEY=replace-me

# Lokal: bosh = SQLite. Prod (Neon): ngjit connection string nga dashboard Neon.
# Shembull: postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

ALLOWED_HOSTS=127.0.0.1,localhost
# Render: emri i plotë i hostit, p.sh. smart-library.onrender.com
# ALLOWED_HOSTS=smart-library.onrender.com

# Dokploy / VPS pa domain (nip.io): vendos host-in nga Dokploy → Domains.
# Shembull: biblioteka.178-104-160-252.nip.io (IP me viza në vend të pikave)
# ALLOWED_HOSTS=biblioteka.178-104-160-252.nip.io,178.104.160.252
#
# CSRF: duhet të përputhet me skemën (http vs https) që përdor shfletuesi.
# HTTPS në Dokploy (toggle + Let’s Encrypt) është falas — përdor https://...
# CSRF_TRUSTED_ORIGINS=https://biblioteka.178-104-160-252.nip.io
# Vetëm HTTP (HTTPS OFF te domain):
# CSRF_TRUSTED_ORIGINS=http://biblioteka.178-104-160-252.nip.io

# HTTPS admin / CSRF (Render): URL me https, presje për më shumë
# CSRF_TRUSTED_ORIGINS=https://smart-library.onrender.com
CSRF_TRUSTED_ORIGINS=

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (MVP: console backend by default)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=
DEFAULT_FROM_EMAIL=
OPS_REPORT_RECIPIENTS=
OPS_ALERT_OVERDUE_LOANS_THRESHOLD=10
OPS_ALERT_OVERDUE_RESERVATIONS_THRESHOLD=5
OPS_ALERT_PENDING_REQUESTS_THRESHOLD=20
OPS_ALERT_UNPAID_FINES_TOTAL_THRESHOLD=1000.00
NOTIFY_DUE_SOON_DAYS=2
NOTIFY_FINE_CREATED_LOOKBACK_DAYS=3
NOTIFY_RESERVATION_EXPIRY_HOURS=24
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
PUBLIC_BASE_URL=
MAINTENANCE_MODE=0

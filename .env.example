DEBUG=1
SECRET_KEY=replace-me

# Lokal: bosh = SQLite. Prod (Neon): ngjit connection string nga dashboard Neon.
# Shembull: postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

ALLOWED_HOSTS=127.0.0.1,localhost
# Render: emri i plotë i hostit, p.sh. smart-library.onrender.com
# ALLOWED_HOSTS=smart-library.onrender.com

# HTTPS admin / CSRF (Render): URL me https, presje për më shumë
# CSRF_TRUSTED_ORIGINS=https://smart-library.onrender.com
CSRF_TRUSTED_ORIGINS=

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

